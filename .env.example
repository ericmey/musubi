# Musubi Core — environment variables.
#
# Copy to `.env` at the repo root (or set MUSUBI_DOTENV to point elsewhere)
# and fill in with values appropriate to your deployment.
#
# Canonical spec: docs/architecture/08-deployment/compose-stack.md §Env.
# Loader: src/musubi/settings.py. Accessor: src/musubi/config.get_settings().
#
# Never commit a filled-in copy of this file. `.env` and `.env.local`
# are already in .gitignore.

# --------------------------------------------------------------------------
# Qdrant
# --------------------------------------------------------------------------
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=change-me

# --------------------------------------------------------------------------
# Inference endpoints
# --------------------------------------------------------------------------
TEI_DENSE_URL=http://tei-dense
TEI_SPARSE_URL=http://tei-sparse
TEI_RERANKER_URL=http://tei-reranker
OLLAMA_URL=http://ollama:11434

EMBEDDING_MODEL=BAAI/bge-m3
SPARSE_MODEL=naver/splade-v3
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
LLM_MODEL=qwen2.5:7b-instruct-q4_K_M

# --------------------------------------------------------------------------
# Core service
# --------------------------------------------------------------------------
BRAIN_PORT=8100
VAULT_PATH=/var/lib/musubi/vault
ARTIFACT_BLOB_PATH=/var/lib/musubi/artifact-blobs
LIFECYCLE_SQLITE_PATH=/var/lib/musubi/lifecycle-work.sqlite
LOG_DIR=/var/log/musubi

# --------------------------------------------------------------------------
# Auth
# --------------------------------------------------------------------------
JWT_SIGNING_KEY=change-me-to-a-long-random-string
OAUTH_AUTHORITY=https://auth.example.test

# --------------------------------------------------------------------------
# Feature flags
# --------------------------------------------------------------------------
MUSUBI_GRPC=false
MUSUBI_ALLOW_PLAINTEXT=false
