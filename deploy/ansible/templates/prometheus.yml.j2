# Prometheus scrape config for the Musubi workload host.
# See [[09-operations/observability]] for the broader strategy and
# [[13-decisions/0033-centralize-observability-on-shiori]] for the
# central-vs-local split.
#
# Rendered into `/etc/musubi/prometheus.yml` on the host by
# `deploy/ansible/deploy.yml`, then mounted read-only at
# `/etc/prometheus/prometheus.yml` inside the prometheus container. A
# SIGHUP reloads without a restart:
#
#     docker compose -f /etc/musubi/docker-compose.yml kill -s HUP prometheus
#
# Every `target` below is a compose service name — resolution happens on
# the musubi compose bridge.
#
# Sample flow: scrape locally → keep 30 days locally (`--storage.tsdb.retention.time=30d`)
# AND remote_write to shiori's Mimir for central aggregation, multi-host
# correlation, and longer-horizon visualization.
#
# Qdrant scrape uses `authorization.credentials_file` to send
# `Authorization: Bearer <api-key>`. Qdrant 1.17 accepts either an
# `api-key:` header or the Bearer form; Prometheus only natively
# supports the Bearer form, so that's what we use. The token file is
# rendered at service start by `op inject` from a committed `op://` reference
# template into `/run/musubi-secrets/qdrant.token`, then mounted into the
# container at `/etc/prometheus/qdrant.token` (mode 0400, UID 65534).
#
# Visualization, alerting, and trace collection live on shiori per ADR 0033.
# Local Grafana/Loki/Tempo/Alertmanager were planned by slice-ops-observability
# but never deployed; the `deploy/{grafana,loki,tempo}/` directories were
# removed in the same PR as this header update.

global:
  scrape_interval: 15s
  scrape_timeout: 10s
  external_labels:
    deployment_environment: harem-world
    host_name: musubi
    service_namespace: musubi

# Mirror every sample to shiori's Mimir. Local TSDB still serves direct
# PromQL queries on 127.0.0.1:9090 if shiori is unreachable.
remote_write:
  - url: http://shiori.mey.house:9009/api/v1/push
    write_relabel_configs:
      # Don't ship prometheus's own scrape-of-itself metrics — shiori has its
      # own prometheus self-metrics; double-counting muddies correlation.
      - source_labels: [job]
        regex: prometheus
        action: drop
      # Promote `job` → `service_name` so musubi-emitted series match the
      # OTel convention used by openclaw/livekit/shiori. See [[wiki/services/observability/integration-baseline#F3.1]].
      - source_labels: [job]
        target_label: service_name
        action: replace

scrape_configs:
  # Musubi Core — HTTP API metrics (request counts, latency histograms,
  # 5xx totals) exposed via prometheus_client on the /v1/ops/metrics
  # endpoint.
  - job_name: musubi-core
    metrics_path: /v1/ops/metrics
    static_configs:
      - targets: ["core:8100"]

  # TEI — each embedder/reranker exposes its own /metrics on port 80
  # (batch latency, queue depth, GPU utilisation).
  - job_name: tei-dense
    metrics_path: /metrics
    static_configs:
      - targets: ["tei-dense:80"]
        labels:
          model: bge-m3

  - job_name: tei-sparse
    metrics_path: /metrics
    static_configs:
      - targets: ["tei-sparse:80"]
        labels:
          model: splade-v3

  - job_name: tei-reranker
    metrics_path: /metrics
    static_configs:
      - targets: ["tei-reranker:80"]
        labels:
          model: bge-reranker-v2-m3

  # Prometheus scrapes itself — cheap, handy for debugging "are scrapes
  # landing at all?" without standing up a separate probe. Dropped from
  # remote_write (see write_relabel_configs above) so shiori's central
  # prometheus self-metrics aren't double-counted.
  - job_name: prometheus
    static_configs:
      - targets: ["localhost:9090"]

  # Qdrant — vector storage. Native Prometheus endpoint at /metrics; auth
  # required. Bearer credentials come from the tmpfs file rendered by
  # `musubi.service` before Compose starts.
  - job_name: qdrant
    metrics_path: /metrics
    authorization:
      type: Bearer
      credentials_file: /etc/prometheus/qdrant.token
    static_configs:
      - targets: ["qdrant:6333"]

  # node-exporter — host-level CPU / memory / disk / network / filesystem.
  # Runs as a sibling container on the musubi compose bridge, mounting
  # /proc, /sys, and / read-only from the host. Per ADR 0033, the host
  # metrics gap is closed by node-exporter (rather than the OTel hostmetrics
  # receiver pattern shiori uses) to avoid disturbing the working scraper.
  - job_name: node-exporter
    static_configs:
      - targets: ["node-exporter:9100"]
